{
    "git": {
      "deploymentEnabled": {
        "main": false
      }
    },
    "outputDirectory": "dist",
    "installCommand": "npm install && cd tavle && npm install",
    "buildCommand": "npm run build:prod",
    "env": {
      "USE_FULL_RESOLUTION_IMAGES": "true"
    },
    "devCommand": "npm run start",
    "routes": [
        { "handle": "filesystem" },
        { "src": "/(.*)", "status": 404, "dest": "/404" }
      ]
}
