{% if "oppgave" in tags %}
<div class="oppgave-kildeinfo">
{% set fagArray = fag | toArray %}
{% if status == 0 %}
<div class="callout" data-callout="warning">
  <div class="callout-title"><div class="callout-icon"></div><div class="callout-title-inner">Ikke kvalitetssikret</div></div>
  <div class="callout-content"><p>Denne oppgaven er lest inn med KI og er ikke kontrollert enda. Det kan forekomme feil.</p></div>
</div>
{% endif %}
<p><em>
{%- if not eksamen or eksamen == "ingen" -%}
  {%- if source -%}
    Oppgaven er hentet fra {{ source }}.
  {%- else -%}
    Oppgaven er ikke hentet fra noe eksamenssett.
  {%- endif -%}
{%- else -%}
  {%- if fagArray | length > 1 -%}
    Oppgaven er gitt ved flere eksamener: {{ fagArray | join(", ") | upper }}.
  {%- endif -%}
  Oppgaven er hentet fra eksamen {{ fagArray[0] | upper }} {{ eksamen | upper }} del {{ del }} oppgave {{ oppgave }}.
{%- endif -%}
</em></p>
</div>
{% endif %}
