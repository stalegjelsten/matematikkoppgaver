    <div x-init="isDesktop = (window.innerWidth>=1000) ? true: false;"
            x-on:resize.window="isDesktop = (window.innerWidth>=1000) ? true : false;"
            x-data="{isDesktop: true, showFilesMobile: false}">

        <div x-show.important="!isDesktop" style="display: none;">
            {%include "components/filetreeNavbar.njk"%}
        </div>

        <div x-show="showFilesMobile && !isDesktop" @click="showFilesMobile = false" style="display:none;" class="fullpage-overlay"></div>

      <div class="filetree-wrapper" x-show.important="isDesktop || showFilesMobile" style="display: none;">
        <div id="filetree-content-container"></div>
      </div>
    </div>
    <script>
      (function() {
        var container = document.getElementById('filetree-content-container');

        function readCount(key, fallback) {
          try {
            var value = JSON.parse(localStorage.getItem(key) || fallback);
            if (Array.isArray(value)) return value.length;
            if (value && typeof value === 'object') return Object.keys(value).length;
          } catch (e) {}
          return 0;
        }

        function updateOppgaveMenu() {
          var listCount = readCount('oppgaveliste', '[]');
          var statusCount = readCount('oppgavestatus', '{}');

          container.querySelectorAll('[data-oppgaveliste-menu-count]').forEach(function(el) {
            el.textContent = listCount;
            el.setAttribute('data-count', String(listCount));
          });

          container.querySelectorAll('[data-oppgavestatus-menu-link]').forEach(function(el) {
            el.hidden = statusCount === 0;
          });
          container.querySelectorAll('[data-oppgavestatus-menu-count]').forEach(function(el) {
            el.textContent = statusCount;
            el.setAttribute('data-count', String(statusCount));
          });
        }

        fetch('/filetree-content/')
          .then(function(r) { return r.text(); })
          .then(function(html) {
            container.innerHTML = html;
            var currentPath = window.location.pathname;
            container.querySelectorAll('.notelink a').forEach(function(a) {
              if (a.getAttribute('href') === currentPath) {
                a.closest('.notelink').classList.add('active-note');
              }
            });
            if (window.Alpine) {
              Alpine.initTree(container);
            } else {
              document.addEventListener('alpine:init', function() {
                Alpine.initTree(container);
              });
            }
            if (window.OppgaveStatus) window.OppgaveStatus.decorate(container);
            updateOppgaveMenu();
            if (typeof lucide !== 'undefined') lucide.createIcons();
          });
        window.addEventListener('storage', function(e) {
          if (e.key === 'oppgaveliste' || e.key === 'oppgavestatus') updateOppgaveMenu();
        });
        window.addEventListener('oppgaveliste:changed', updateOppgaveMenu);
        window.addEventListener('oppgavestatus:changed', updateOppgaveMenu);
      })();
    </script>
