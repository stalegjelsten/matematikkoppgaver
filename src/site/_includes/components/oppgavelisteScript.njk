<script>
(function() {
  const STORAGE_KEY = 'oppgaveliste';
  const MODE_KEY = 'oppgaveliste-view-mode';

  const root = document.getElementById('oppgaveliste-app');

  function read() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
    catch { return []; }
  }
  function write(list) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
  }
  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, c => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    }[c]));
  }

  function slugToToken(slug) {
    return encodeURIComponent(slug.replace(/^\/+|\/+$/g, ''));
  }
  function tokenToSlug(token) {
    const inner = decodeURIComponent(token).replace(/^\/+|\/+$/g, '');
    return '/' + inner + '/';
  }
  function slugToFallbackTitle(slug) {
    return decodeURIComponent(slug.replace(/^\/+|\/+$/g, '').replace(/-/g, ' '));
  }
  function persistSharedList(items) {
    const now = Date.now();
    const list = items.map((it, i) => ({
      slug: it.slug,
      title: it.title || slugToFallbackTitle(it.slug),
      addedAt: now + i,
    }));
    write(list);
    window.dispatchEvent(new CustomEvent('oppgaveliste:changed'));
  }
  function appendSharedToExisting(existing, items) {
    const seen = new Set(existing.map(x => x.slug));
    const now = Date.now();
    const additions = items
      .filter(it => !seen.has(it.slug))
      .map((it, i) => ({
        slug: it.slug,
        title: it.title || slugToFallbackTitle(it.slug),
        addedAt: now + i,
      }));
    if (additions.length === 0) return false;
    write(existing.concat(additions));
    window.dispatchEvent(new CustomEvent('oppgaveliste:changed'));
    return true;
  }
  function updateTitlesInStorage(oppgaver) {
    const titleMap = new Map(oppgaver.filter(o => o.title).map(o => [o.slug, o.title]));
    if (titleMap.size === 0) return;
    const list = read();
    let changed = false;
    for (const item of list) {
      const t = titleMap.get(item.slug);
      if (t && item.title !== t) {
        item.title = t;
        changed = true;
      }
    }
    if (changed) {
      write(list);
      window.dispatchEvent(new CustomEvent('oppgaveliste:changed'));
    }
  }
  function showShareDialog(sharedCount, existingCount) {
    return new Promise(resolve => {
      const overlay = document.createElement('div');
      overlay.className = 'oppgaveliste-dialog-overlay';
      overlay.innerHTML = `
        <div class="oppgaveliste-dialog" role="dialog" aria-modal="true" aria-labelledby="ol-dialog-title">
          <h2 id="ol-dialog-title">Du har allerede oppgaver i lista</h2>
          <p>Du har ${existingCount} ${existingCount === 1 ? 'oppgave' : 'oppgaver'} i oppgavelista di. Hva vil du gjøre med ${sharedCount === 1 ? 'oppgaven' : 'de ' + sharedCount + ' oppgavene'} fra delelenken?</p>
          <div class="oppgaveliste-dialog-actions">
            <button type="button" class="ol-btn ol-btn-primary" data-choice="append">Legg til oppgavene i oppgavelista</button>
            <button type="button" class="ol-btn ol-btn-danger" data-choice="replace">Erstatt oppgavelista med disse oppgavene</button>
            <button type="button" class="ol-btn ol-btn-ghost" data-choice="cancel">Bare vis denne gangen</button>
          </div>
        </div>
      `;
      function pick(choice) {
        document.removeEventListener('keydown', onEsc);
        overlay.remove();
        resolve(choice);
      }
      function onEsc(e) {
        if (e.key === 'Escape') pick('cancel');
      }
      overlay.addEventListener('click', (e) => {
        const btn = e.target.closest('[data-choice]');
        if (btn) pick(btn.dataset.choice);
        else if (e.target === overlay) pick('cancel');
      });
      document.addEventListener('keydown', onEsc);
      document.body.appendChild(overlay);
      const firstBtn = overlay.querySelector('[data-choice="append"]');
      if (firstBtn) firstBtn.focus();
    });
  }

  function getSharedSlugs() {
    const params = new URLSearchParams(window.location.search);
    const raw = params.get('o');
    if (!raw) return null;
    return raw.split(',').filter(Boolean).map(tokenToSlug);
  }

  function buildShareQuery(list) {
    return list.map(x => slugToToken(x.slug)).join(',');
  }

  function buildShareUrl(list) {
    const base = window.location.origin + window.location.pathname;
    return `${base}?o=${buildShareQuery(list)}`;
  }

  function renderStatusButtons(slug, variant = '') {
    const cls = variant ? ` oppgaveliste-status-buttons--${variant}` : '';
    return `
      <div class="oppgaveliste-status-buttons${cls}" data-oppgavestatus-controls data-slug="${escapeHtml(slug)}" role="radiogroup" aria-label="Marker hvordan det gikk med oppgaven">
        <button type="button" class="oppgaveliste-status-btn" data-oppgavestatus-set="done" role="radio" aria-checked="false" title="Fikk det til">
          <span class="oppgaveliste-status-icon" data-oppgavestatus-icon="done" aria-hidden="true"></span>
          <span class="oppgaveliste-status-label">Fikk det til</span>
        </button>
        <button type="button" class="oppgaveliste-status-btn" data-oppgavestatus-set="review" role="radio" aria-checked="false" title="Må repetere">
          <span class="oppgaveliste-status-icon" data-oppgavestatus-icon="review" aria-hidden="true"></span>
          <span class="oppgaveliste-status-label">Må repetere</span>
        </button>
        <button type="button" class="oppgaveliste-status-btn" data-oppgavestatus-set="failed" role="radio" aria-checked="false" title="Fikk det ikke til">
          <span class="oppgaveliste-status-icon" data-oppgavestatus-icon="failed" aria-hidden="true"></span>
          <span class="oppgaveliste-status-label">Fikk det ikke til</span>
        </button>
      </div>
    `;
  }

  function setupStatusButtons(container) {
    if (!window.OppgaveStatus || !container) return;

    container.querySelectorAll('[data-oppgavestatus-icon]').forEach(el => {
      const key = el.getAttribute('data-oppgavestatus-icon');
      el.innerHTML = window.OppgaveStatus.ICONS[key] || '';
    });

    container.querySelectorAll('[data-oppgavestatus-controls]').forEach(group => {
      if (group.dataset.statusBound === '1') return;
      group.dataset.statusBound = '1';
      group.querySelectorAll('[data-oppgavestatus-set]').forEach(btn => {
        btn.addEventListener('click', () => {
          const slug = group.getAttribute('data-slug');
          const value = btn.getAttribute('data-oppgavestatus-set');
          const current = window.OppgaveStatus.get(slug);
          window.OppgaveStatus.set(slug, value === current ? null : value);
        });
      });
    });

    updateStatusButtons(container);
  }

  function updateStatusButtons(container = root) {
    if (!window.OppgaveStatus || !container) return;
    container.querySelectorAll('[data-oppgavestatus-controls]').forEach(group => {
      const current = window.OppgaveStatus.get(group.getAttribute('data-slug'));
      group.querySelectorAll('[data-oppgavestatus-set]').forEach(btn => {
        const active = btn.getAttribute('data-oppgavestatus-set') === current;
        btn.classList.toggle('is-active', active);
        btn.setAttribute('aria-checked', active ? 'true' : 'false');
      });
      group.setAttribute('data-current-status', current || '');
    });
  }

  // ===== Editor mode =====

  function renderEditor() {
    const list = read();

    if (list.length === 0) {
      root.innerHTML = `
        <div class="oppgaveliste-empty">
          <p>Du har ingen oppgaver i oppgavelista ennå.</p>
          <p>Gå til en oppgaveside og klikk «Legg til i oppgavelista».</p>
        </div>
      `;
      return;
    }

    const itemsHtml = list.map((item, i) => `
      <li class="oppgaveliste-item" data-index="${i}">
        <div class="oppgaveliste-item-info">
          <span class="oppgaveliste-item-num">${i + 1}.</span>
          <a href="${escapeHtml(item.slug)}" class="oppgaveliste-item-title">${escapeHtml(item.title)}</a>
        </div>
        ${renderStatusButtons(item.slug, 'compact')}
        <div class="oppgaveliste-item-actions">
          <button type="button" class="ol-icon-btn" data-action="up" ${i === 0 ? 'disabled' : ''} title="Flytt opp" aria-label="Flytt opp">↑</button>
          <button type="button" class="ol-icon-btn" data-action="down" ${i === list.length - 1 ? 'disabled' : ''} title="Flytt ned" aria-label="Flytt ned">↓</button>
          <button type="button" class="ol-icon-btn ol-icon-btn-danger" data-action="remove" title="Fjern" aria-label="Fjern">✕</button>
        </div>
      </li>
    `).join('');

    const shareUrl = buildShareUrl(list);

    root.innerHTML = `
      <p class="oppgaveliste-intro">${list.length} ${list.length === 1 ? 'oppgave' : 'oppgaver'} i oppgavelista. Endre rekkefølgen, fjern eller del lista med en elev.</p>
      <ol class="oppgaveliste-list">${itemsHtml}</ol>

      <div class="oppgaveliste-actions">
        <a href="?o=${buildShareQuery(list)}" class="ol-btn ol-btn-primary">Vis som elev</a>
        <button type="button" class="ol-btn" data-global-action="copy">Kopier delelenke</button>
        <button type="button" class="ol-btn ol-btn-danger" data-global-action="clear">Tøm lista</button>
      </div>

      <details class="oppgaveliste-share-url">
        <summary>Vis delelenke</summary>
        <input type="text" readonly value="${escapeHtml(shareUrl)}" onclick="this.select()" />
      </details>
    `;

    root.querySelectorAll('.oppgaveliste-item').forEach(li => {
      const i = parseInt(li.dataset.index, 10);
      li.querySelectorAll('[data-action]').forEach(btn => {
        btn.addEventListener('click', () => handleItemAction(i, btn.dataset.action));
      });
    });

    root.querySelectorAll('[data-global-action]').forEach(btn => {
      btn.addEventListener('click', () => handleGlobalAction(btn.dataset.globalAction, shareUrl));
    });

    setupStatusButtons(root);
    if (window.OppgaveStatus) window.OppgaveStatus.decorate(root);
  }

  function handleItemAction(i, action) {
    const list = read();
    if (action === 'remove') {
      list.splice(i, 1);
    } else if (action === 'up' && i > 0) {
      [list[i - 1], list[i]] = [list[i], list[i - 1]];
    } else if (action === 'down' && i < list.length - 1) {
      [list[i + 1], list[i]] = [list[i], list[i + 1]];
    }
    write(list);
    window.dispatchEvent(new CustomEvent('oppgaveliste:changed'));
    renderEditor();
  }

  function handleGlobalAction(action, shareUrl) {
    if (action === 'copy') {
      navigator.clipboard.writeText(shareUrl).then(() => {
        const btn = root.querySelector('[data-global-action="copy"]');
        if (!btn) return;
        const original = btn.textContent;
        btn.textContent = 'Kopiert ✓';
        btn.classList.add('is-copied');
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove('is-copied');
        }, 1800);
      }).catch(() => alert('Klarte ikke kopiere. Marker URL-en og kopier manuelt.'));
    } else if (action === 'clear') {
      if (confirm('Tøm hele oppgavelista?')) {
        write([]);
        window.dispatchEvent(new CustomEvent('oppgaveliste:changed'));
        renderEditor();
      }
    }
  }

  // ===== Viewer mode =====

  async function fetchOppgave(slug) {
    try {
      const res = await fetch(slug);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const html = await res.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');

      const main = doc.querySelector('main.content, .cm-s-obsidian, article, main');
      if (!main) return { slug, error: 'Fant ikke innhold' };

      // Pull title from h1, fall back to <title>
      const h1 = main.querySelector('h1');
      const title = h1 ? h1.textContent.trim() : (doc.title || slug);

      // Build clean output: header (without timestamps) + article only.
      // This drops afterContent dynamics like "Relatert" / "Tilfeldige oppgaver".
      const articleEl = main.querySelector('article');
      let cleanHtml = '';
      if (articleEl) {
        // Strip own oppgaveliste-button-container if it bled in via article
        articleEl.querySelectorAll('.oppgaveliste-button-container, .handleliste-button-container').forEach(el => el.remove());
        const beforeHtml = Array.from(main.querySelectorAll('.oppgave-kildeinfo'))
          .map(el => el.outerHTML)
          .join('');
        cleanHtml = beforeHtml + articleEl.innerHTML;
      } else {
        // Fallback: use main but strip noise
        main.querySelectorAll('.oppgaveliste-button-container, .handleliste-button-container, nav, .sidebar, .timestamps').forEach(el => el.remove());
        cleanHtml = main.innerHTML;
      }

      return { slug, title, html: cleanHtml };
    } catch (err) {
      return { slug, error: err.message };
    }
  }

  async function typesetMath(container) {
    if (!window.MathJax) return;
    try {
      if (MathJax.startup && MathJax.startup.promise) {
        await MathJax.startup.promise;
      }
      MathJax.typesetClear([container]);
      await MathJax.typesetPromise([container]);
    } catch (e) { console.warn('MathJax typeset failed:', e); }
  }

  function setupCallouts(container) {
    if (container.dataset.olCalloutsBound) return;
    container.dataset.olCalloutsBound = '1';
    container.addEventListener('click', (e) => {
      const title = e.target.closest('.callout-title');
      if (!title || !container.contains(title)) return;
      const callout = title.closest('.callout.is-collapsible');
      if (!callout) return;
      callout.classList.toggle('is-collapsed');
    });
  }

  function setupLucide(container) {
    if (typeof lucide !== 'undefined') {
      lucide.createIcons({ icons: undefined, attrs: {}, nameAttr: 'data-lucide' });
    }
  }

  async function renderViewer(slugs) {
    const initialMode = localStorage.getItem(MODE_KEY) || 'set';
    const existing = read();

    // If the local list is empty, save shared list immediately so it survives navigation.
    // If non-empty, ask user via dialog whether to append, replace, or just view.
    if (existing.length === 0) {
      persistSharedList(slugs.map(slug => ({ slug })));
    } else {
      // Fire dialog asynchronously — viewer renders in parallel.
      showShareDialog(slugs.length, existing.length).then(choice => {
        if (choice === 'append') {
          appendSharedToExisting(read(), slugs.map(slug => ({ slug })));
        } else if (choice === 'replace') {
          persistSharedList(slugs.map(slug => ({ slug })));
        }
      });
    }

    root.innerHTML = `
      <div class="oppgaveliste-viewer-toolbar">
        <a href="?" class="ol-btn ol-btn-ghost">← Tilbake til redigering</a>
        <div class="oppgaveliste-mode-toggle" role="tablist">
          <button type="button" class="ol-mode-btn ${initialMode === 'set' ? 'is-active' : ''}" data-mode="set" role="tab" aria-selected="${initialMode === 'set'}">Alle på én side</button>
          <button type="button" class="ol-mode-btn ${initialMode === 'slide' ? 'is-active' : ''}" data-mode="slide" role="tab" aria-selected="${initialMode === 'slide'}">Én av gangen</button>
        </div>
        <span class="oppgaveliste-viewer-count">${slugs.length} ${slugs.length === 1 ? 'oppgave' : 'oppgaver'}</span>
      </div>
      <div id="oppgaveliste-viewer-body" class="oppgaveliste-viewer-body"></div>
    `;

    const body = document.getElementById('oppgaveliste-viewer-body');
    body.innerHTML = `<p class="oppgaveliste-loading">Laster oppgaver …</p>`;

    const oppgaver = await Promise.all(slugs.map(fetchOppgave));

    // Update titles in storage for any matching slugs (no-op if user chose 'cancel')
    updateTitlesInStorage(oppgaver);

    body.innerHTML = '';
    oppgaver.forEach((o, i) => {
      const wrap = document.createElement('section');
      wrap.className = 'oppgaveliste-oppgave';
      wrap.dataset.index = i;
      if (o.error) {
        wrap.innerHTML = `
          <div class="oppgaveliste-oppgave-error">
            <h2>Kunne ikke laste «${escapeHtml(o.slug)}»</h2>
            <p>${escapeHtml(o.error)}</p>
          </div>
        `;
      } else {
        wrap.innerHTML = `
          <div class="oppgaveliste-oppgave-header">
            <span class="oppgaveliste-oppgave-num">Oppgave ${i + 1} av ${oppgaver.length}</span>
            <div class="oppgaveliste-oppgave-header-actions">
              ${renderStatusButtons(o.slug, 'viewer')}
              <a href="${escapeHtml(o.slug)}" class="oppgaveliste-oppgave-link" target="_blank" rel="noopener">Åpne i ny fane ↗</a>
            </div>
          </div>
          <div class="oppgaveliste-oppgave-content cm-s-obsidian markdown-preview-view">${o.html}</div>
        `;
      }
      body.appendChild(wrap);
    });

    setupCallouts(body);
    setupLucide(body);
    await typesetMath(body);

    setupStatusButtons(root);
    if (window.OppgaveStatus) window.OppgaveStatus.decorate(root);

    applyMode(initialMode);

    // Mode toggle
    root.querySelectorAll('.ol-mode-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.mode;
        localStorage.setItem(MODE_KEY, mode);
        root.querySelectorAll('.ol-mode-btn').forEach(b => {
          b.classList.toggle('is-active', b.dataset.mode === mode);
          b.setAttribute('aria-selected', b.dataset.mode === mode);
        });
        applyMode(mode);
      });
    });

    // Keyboard nav for slideshow
    document.addEventListener('keydown', onKeydown);
  }

  let currentSlideIdx = 0;
  let currentMode = 'set';

  function applyMode(mode) {
    currentMode = mode;
    const body = document.getElementById('oppgaveliste-viewer-body');
    if (!body) return;
    body.classList.toggle('mode-set', mode === 'set');
    body.classList.toggle('mode-slide', mode === 'slide');

    if (mode === 'slide') {
      ensureSlideControls();
      showSlide(currentSlideIdx);
    } else {
      removeSlideControls();
      // show all
      body.querySelectorAll('.oppgaveliste-oppgave').forEach(el => el.classList.remove('is-hidden'));
    }
  }

  function ensureSlideControls() {
    if (document.getElementById('oppgaveliste-slide-controls')) return;
    const ctrl = document.createElement('div');
    ctrl.id = 'oppgaveliste-slide-controls';
    ctrl.className = 'oppgaveliste-slide-controls';
    ctrl.innerHTML = `
      <button type="button" class="ol-btn" data-slide="prev" aria-label="Forrige">← Forrige</button>
      <span class="oppgaveliste-slide-indicator" aria-live="polite"></span>
      <button type="button" class="ol-btn" data-slide="next" aria-label="Neste">Neste →</button>
    `;
    document.getElementById('oppgaveliste-viewer-body').after(ctrl);
    ctrl.querySelector('[data-slide="prev"]').addEventListener('click', () => showSlide(currentSlideIdx - 1));
    ctrl.querySelector('[data-slide="next"]').addEventListener('click', () => showSlide(currentSlideIdx + 1));
  }

  function removeSlideControls() {
    const ctrl = document.getElementById('oppgaveliste-slide-controls');
    if (ctrl) ctrl.remove();
  }

  function showSlide(idx) {
    const body = document.getElementById('oppgaveliste-viewer-body');
    if (!body) return;
    const items = body.querySelectorAll('.oppgaveliste-oppgave');
    if (items.length === 0) return;
    if (idx < 0) idx = 0;
    if (idx >= items.length) idx = items.length - 1;
    currentSlideIdx = idx;

    items.forEach((el, i) => el.classList.toggle('is-hidden', i !== idx));

    const indicator = document.querySelector('.oppgaveliste-slide-indicator');
    if (indicator) indicator.textContent = `${idx + 1} av ${items.length}`;

    const prev = document.querySelector('[data-slide="prev"]');
    const next = document.querySelector('[data-slide="next"]');
    if (prev) prev.disabled = idx === 0;
    if (next) next.disabled = idx === items.length - 1;

    items[idx].scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function onKeydown(e) {
    if (currentMode !== 'slide') return;
    if (e.target && /^(INPUT|TEXTAREA|SELECT)$/.test(e.target.tagName)) return;
    if (e.key === 'ArrowLeft') { showSlide(currentSlideIdx - 1); }
    else if (e.key === 'ArrowRight') { showSlide(currentSlideIdx + 1); }
  }

  // ===== Init =====

  function init() {
    if (!root) return;
    window.addEventListener('oppgavestatus:changed', () => updateStatusButtons(root));
    window.addEventListener('storage', e => {
      if (e.key === (window.OppgaveStatus && window.OppgaveStatus.KEY)) updateStatusButtons(root);
    });
    const sharedSlugs = getSharedSlugs();
    if (sharedSlugs && sharedSlugs.length > 0) {
      renderViewer(sharedSlugs);
    } else {
      renderEditor();
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
